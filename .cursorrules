---
description: 
alwaysApply: true
---

# ==============================================================================
# CURSOR ARCHITECTURE RULES: WORLD CUP 2026 PREDICTOR APP
# ==============================================================================

[project]
name = "WC2026 Predictor & Gamification"
tech_stack = ["Python 3.12", "Streamlit", "Pandas", "Plotly Express", "Raw HTML/CSS"]
architecture = "MVC (Model-View-Controller) / Service-Oriented"

# ------------------------------------------------------------------------------
# 1. ARCHITECTURAL & CORE FILES MAP
# ------------------------------------------------------------------------------
[files]
ui_components = "ui_components.py (Handles all Raw HTML/CSS rendering via _html())"
analytics_service = "analytics_service.py (Data aggregation, matrix, forecasts)"
achievement_service = "achievement_service.py (HP bar math, badge history/rules evaluation)"
leaderboard_service = "leaderboard_service.py (Points, fines calculation, leaderboard builder)"
main_pages = "pages/3_Bang_Xep_Hang.py (Main Controller for ranking view)"

# ------------------------------------------------------------------------------
# 2. CORE MATHEMATICS & LOGIC RULES
# ------------------------------------------------------------------------------
[rules.gamification]
hp_math = """
- MAX_HP = 104 (Tương đương ngân sách phạt tối đa 1.040.000 VNĐ).
- 1 HP = 10.000 VNĐ.
- Cột 'fines' hoặc 'cum_fines' lưu đơn vị theo hệ số 10 (Ví dụ: phạt 50k -> lưu giá trị 50 -> trừ đi 5 HP).
- Luôn sử dụng hàm `compute_hp_fields(fines_k)` từ `achievement_service.py` để tính HP, không tự viết lại logic.
"""

allowed_metrics = [
    "total_penalties", "points", "hit_rate", "correct", 
    "missed", "played", "remaining_hp", "win_streak", "lose_streak"
]

badge_rarities = ["Common", "Rare", "Legend"]

# ------------------------------------------------------------------------------
# 3. DATAFRAME & DATA TYPES STRICTNESS
# ------------------------------------------------------------------------------
[rules.data_types]
strict_casting = """
- 'user_id' và 'match_id' LUÔN LUÔN phải được ép kiểu thành Chuỗi (String) qua `.astype(str)` trước khi merge, groupby hoặc lookup.
- 'points' và 'fines' phải được chuyển về dữ liệu số bằng `pd.to_numeric(..., errors="coerce").fillna(0)`.
"""

timezone_handling = """
- 'kickoff_vn' và 'timestamp' khi biến đổi bằng `pd.to_datetime()` bắt buộc phải truyền tham số `format="mixed", errors="coerce", utc=True` để tránh lỗi 'TypeError: Cannot subtract tz-naive and tz-aware'.
"""

# ------------------------------------------------------------------------------
# 4. UI RENDERING & STYLING RULES
# ------------------------------------------------------------------------------
[rules.ui_rendering]
streamlit_ban = """
- KHÔNG sử dụng `st.metric` mặc định cho các Header Banner hoặc Dashboard quan trọng ngoại trừ khi debug.
- Tất cả cấu trúc Card Danh hiệu (Hero Cards) trên đỉnh Leaderboard phải được render thông qua hàm `render_lb_hero_cards(leaderboard)` trong `ui_components.py` để đảm bảo đồng bộ layout HTML/CSS.
- Mọi hàm vẽ HTML trong `ui_components.py` phải đóng gói thẻ class CSS chuẩn (`stat-card`, `stats-row`, `lb-hero-card`) và hiển thị qua hàm wrapper `_html()`.
"""

# ------------------------------------------------------------------------------
# 5. CODING STYLE & WORKFLOW PROMPTS
# ------------------------------------------------------------------------------
[rules.workflow]
instructions = """
1. Khi chỉnh sửa danh hiệu (Badges), hãy ưu tiên cập nhật cấu trúc dữ liệu payload trong file `ui_components.py` (hàm `_lb_hero_cards_payload`) hoặc file Excel cấu hình, tránh viết đè logic tính toán thô vào file giao diện `3_Bang_Xep_Hang.py`.
2. Giữ nguyên tính chất tách biệt: Controller (`3_Bang_Xep_Hang.py`) lo tính toán biến số -> View (`ui_components.py`) lo render HTML.
3. Khi viết code so sánh toán học, luôn phòng thủ trường hợp DataFrame trống hoặc thiếu cột bằng cách bọc khối lệnh `if not df.empty:` và `.get(column, default)`.
"""
